NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Reddit Ads — browser pixel (public). Default matches Ads Manager "Install the Pixel".
NEXT_PUBLIC_REDDIT_PIXEL_ID=a2_irrbb7hibeno

# Reddit Conversions API (server-only). Account ID is from Reddit Ads dashboard (path segment for CAPI), not always the same as the pixel id.
# Generate token: Ads Manager → Set up Conversions API → Generate access token.
REDDIT_ADS_ACCOUNT_ID=
REDDIT_CONVERSION_ACCESS_TOKEN=
BASEHUB_TOKEN="<basehub_token>"
REPLAY_API_KEY="<replay_api_key>"
BASEHUB_DRAFT=true
DRAFT_MODE=true
REPLAY_PLAYWRIGHT_FIXTURE=true
INTERCOM_ACCESS_TOKEN="<intercom_access_token>"
ATTIO_API_KEY="<attio_api_key>"
# Contact form emails (Resend). CONTACT_FORM_FROM must use a domain verified in your Resend account
# (for local testing you can use the default onboarding address from the Resend dashboard).
RESEND_API_KEY="<resend_api_key>"
CONTACT_FORM_TO="info@replay.io"
CONTACT_FORM_FROM="Replay Contact <contact@replay.io>"